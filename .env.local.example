# wowkids-website

# Supabase Configuration
# Get these from: Supabase Dashboard > Project Settings > API

# Required: Your Supabase project URL (starts with https://)
NEXT_PUBLIC_SUPABASE_URL=your-project-url

# Required: Your Supabase anon/public key (starts with eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required (server-side): Your Supabase service_role key (starts with eyJ...)
# Get this from: Supabase Dashboard > Project Settings > API > service_role key
# This is used by the admin login system to look up user profiles securely.
# WARNING: Never share this key publicly or expose it in client-side code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
